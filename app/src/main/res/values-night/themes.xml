<resources>
    <style name="Theme.Giku.Dark" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color with sufficient contrast -->
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant_dark</item>
        <item name="colorOnPrimary">@color/on_primary_dark</item>

        <!-- Secondary color for contrast (teal tones for visibility) -->
        <item name="colorSecondary">@color/secondary_dark</item>
        <item name="colorSecondaryVariant">@color/secondary_variant_dark</item>
        <item name="colorOnSecondary">@color/on_secondary_dark</item>

        <!-- Background and Surface Colors -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnBackground">@color/on_background_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>

        <!-- Status Bar and Navigation Bar Colors -->
        <item name="android:statusBarColor">@color/primary_variant_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Error Colors -->
        <item name="colorError">@color/error_dark</item>
        <item name="colorOnError">@color/on_error_dark</item>

        <!-- Toolbar Styling -->
        <item name="toolbarStyle">@style/Widget.Giku.Dark.Toolbar</item>

        <!-- Floating Action Button (FAB) Styling -->
        <item name="floatingActionButtonStyle">@style/Widget.Giku.Dark.FloatingActionButton</item>

        <!-- Text Appearance for Headings and Body Text -->
        <item name="textAppearanceHeadline1">@style/TextAppearance.Giku.Dark.Headline1</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.Giku.Dark.Headline2</item>
        <item name="textAppearanceBody1">@style/TextAppearance.Giku.Dark.Body1</item>
        <item name="textAppearanceBody2">@style/TextAppearance.Giku.Dark.Body2</item>
        <item name="textAppearanceButton">@style/TextAppearance.Giku.Dark.Button</item>

        <!-- Button Styling -->
        <item name="buttonStyle">@style/Widget.Giku.Dark.Button</item>

        <!-- CardView Styling -->
        <item name="cardViewStyle">@style/Widget.Giku.Dark.CardView</item>

        <!-- Icon and Ripple Color for better visibility -->
        <item name="colorControlNormal">@color/on_surface_dark</item>
        <item name="colorControlActivated">@color/secondary_variant_dark</item>
        <item name="colorControlHighlight">@color/secondary_dark</item>
        <item name="colorAccent">@color/secondary_dark</item>

        <!-- Dialog and AlertDialog Styling -->
        <item name="dialogTheme">@style/ThemeOverlay.Giku.Dark.Dialog</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.Giku.Dark.AlertDialog</item>
    </style>

    <!-- Toolbar Style -->
    <style name="Widget.Giku.Dark.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/primary_dark</item>
        <item name="titleTextColor">@color/on_primary_dark</item>
        <item name="subtitleTextColor">@color/on_primary_dark</item>
    </style>

    <!-- Floating Action Button (FAB) Style -->
    <style name="Widget.Giku.Dark.FloatingActionButton" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/secondary_dark</item>
        <item name="rippleColor">@color/secondary_variant_dark</item>
    </style>

    <!-- Text Appearances for various text styles -->
    <style name="TextAppearance.Giku.Dark.Headline1" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="android:textColor">@color/on_background_dark</item>
    </style>
    <style name="TextAppearance.Giku.Dark.Headline2" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="android:textColor">@color/on_background_dark</item>
    </style>
    <style name="TextAppearance.Giku.Dark.Body1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/on_surface_dark</item>
    </style>
    <style name="TextAppearance.Giku.Dark.Body2" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/on_surface_dark</item>
    </style>
    <style name="TextAppearance.Giku.Dark.Button" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textColor">@color/on_secondary_dark</item>
    </style>

    <!-- Button Style -->
    <style name="Widget.Giku.Dark.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/secondary_dark</item>
        <item name="rippleColor">@color/secondary_variant_dark</item>
        <item name="android:textColor">@color/on_secondary_dark</item>
    </style>

    <!-- CardView Style -->
    <style name="Widget.Giku.Dark.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_dark</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- Dialog and AlertDialog Theme Overlay -->
    <style name="ThemeOverlay.Giku.Dark.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
    </style>
    <style name="ThemeOverlay.Giku.Dark.AlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/on_primary_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
    </style>
</resources>
